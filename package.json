{
  "name": "@esso0428/pi-skill-tags",
  "version": "0.1.1",
  "description": "Inline skill tags with autocomplete for the Pi coding agent",
  "type": "module",
  "license": "MIT",
  "author": "esso0428",
  "homepage": "https://github.com/esso0428/pi-skill-tags#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/esso0428/pi-skill-tags.git"
  },
  "bugs": {
    "url": "https://github.com/esso0428/pi-skill-tags/issues"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "pi-coding-agent",
    "skill-tags",
    "skills",
    "autocomplete",
    "tui"
  ],
  "files": [
    "index.ts",
    "skill-tags.ts",
    "docs/skill-tags.png",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=22.19"
  },
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "test": "node --experimental-transform-types --test tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm test",
    "check:release-gate": "node scripts/npm-prepush-gate.mjs --check-main",
    "setup-hooks": "git config core.hooksPath .githooks",
    "prepublishOnly": "npm run check"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.7",
    "@earendil-works/pi-tui": "^0.80.7",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  }
}
